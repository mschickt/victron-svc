# victron-svc device configuration — copy to ".env" and fill in real values.
#
#   cp .env.example .env
#   # edit .env, then:
#   ./start.sh            # docker compose up -d --build
#
# The ".env" file is read by Docker Compose on the host and injected into the
# container as environment variables. It is gitignored and is NOT baked into
# the image. SmallRye Config maps each VICTRON_DEVICES_<n>_<FIELD> variable onto
# victron.devices[<n>].<field>, so devices are defined entirely here — no entries
# in application.yml are required.
#
# Indices must be contiguous starting at 0 (0, 1, 2, ...).
# TYPE is one of: MPPT, SMART_SHUNT, ORION_TR
# ADVERTISEMENT_KEY is the 32-hex-char key from VictronConnect
#   (Device -> ⋮ -> Product info -> Instant readout -> Advertisement Key).
#   This is NOT the 6-digit Bluetooth pairing PIN.

# --- Device 0: Solar ext. (MPPT) ---
VICTRON_DEVICES_0_MAC=EE:CC:44:F2:D8:79
VICTRON_DEVICES_0_NAME=Solar ext.
VICTRON_DEVICES_0_TYPE=MPPT
VICTRON_DEVICES_0_ADVERTISEMENT_KEY=REPLACE_WITH_SOLAR_EXT_KEY

# --- Device 1: Solar Dach (MPPT) ---
VICTRON_DEVICES_1_MAC=C3:AC:9F:3B:0B:4C
VICTRON_DEVICES_1_NAME=Solar Dach
VICTRON_DEVICES_1_TYPE=MPPT
VICTRON_DEVICES_1_ADVERTISEMENT_KEY=REPLACE_WITH_SOLAR_DACH_KEY

# --- Device 2: SmartShunt Goldi (SmartShunt) ---
VICTRON_DEVICES_2_MAC=DE:9A:A6:20:20:E3
VICTRON_DEVICES_2_NAME=SmartShunt Goldi
VICTRON_DEVICES_2_TYPE=SMART_SHUNT
VICTRON_DEVICES_2_ADVERTISEMENT_KEY=REPLACE_WITH_SMARTSHUNT_KEY

# --- Optional: BLE scanner overrides (defaults live in application.yml) ---
# VICTRON_BLE_ADAPTER=hci0
# VICTRON_BLE_SCAN_INTERVAL=2s
# VICTRON_BLE_AUTO_START=true
